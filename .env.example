# Copiá este archivo a .env y completá los valores
# NOTA: .env está en .gitignore, no se sube al repositorio

# Motor de base de datos (MySQL, SQLite, PostgreSQL, etc.)
# DATABASE_URL=mysql://usuario:contraseña@localhost:3306/dbFiadoApp
# DATABASE_URL=sqlite:///db.sqlite3

# Modo debug: True para desarrollo, False para producción
# DJANGO_DEBUG=True

# Clave secreta para firmar tokens JWT y sesiones
# IMPORTANTE: Generar una clave única por instalación
# DJANGO_SECRET_KEY=poné_una_clave_segura_acá

# Contraseña del usuario admin que se crea en la primera instalación
# Colocá en el .env la contraseña que desee
# DJANGO_ADMIN_PASSWORD=colocar_aqui_la_contraseña
