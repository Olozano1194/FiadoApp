{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FiadoApp",
  "version": "0.1.0",
  "identifier": "com.fiadoapp.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FiadoApp — Sistema POS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8000 http://localhost:8000; img-src 'self' asset: http://127.0.0.1:8000 data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "FiadoApp",
    "externalBin": ["binaries/fiadoapp-backend"],
    "resources": {
      "binaries/_internal/": "_internal/"
    },
    "windows": {
      "wix": {
        "language": "es-ES"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
